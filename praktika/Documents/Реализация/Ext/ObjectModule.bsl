Процедура ОбработкаПроведения(Отказ, Режим)

    Движения.ОстаткиТоваров.Записывать = Истина;
    Движения.Продажи.Записывать = Истина;
    Движения.СтоимостьТоваров.Записывать = Истина;
    Движения.ОстаткиТоваров.БлокироватьДляИзменения = Истина;
    Движения.СтоимостьТоваров.БлокироватьДляИзменения = Истина;

    Запрос = Новый Запрос;
    Запрос.УстановитьПараметр("Ссылка", Ссылка);
    Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
    Запрос.Текст =
    "ВЫБРАТЬ
    |	СУММА(ОстаткиТоваровОстатки.КоличествоОстаток) КАК КоличествоОстаток,
    |	РеализацияТовары.Товар КАК Товар,
    |	СУММА(РеализацияТовары.Количество) КАК Количество,
    |	СУММА(РеализацияТовары.Сумма) КАК Сумма
    |ИЗ
    |	Документ.Реализация.Товары КАК РеализацияТовары
    |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(&МоментВремени, ) КАК ОстаткиТоваровОстатки
    |		ПО (ОстаткиТоваровОстатки.Товар = РеализацияТовары.Товар)
    |ГДЕ
    |	РеализацияТовары.Ссылка = &Ссылка
    |СГРУППИРОВАТЬ ПО
    |	РеализацияТовары.Товар";

    РезультатЗапроса = Запрос.Выполнить();
    ВыборкаТовары = РезультатЗапроса.Выбрать();

    Пока ВыборкаТовары.Следующий() Цикл

        // Регистр ОстаткиТоваров - Расход
        Движение = Движения.ОстаткиТоваров.Добавить();
        Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
        Движение.Период = Дата;
        Движение.Товар = ВыборкаТовары.Товар;
        Движение.Количество = ВыборкаТовары.Количество;

        // Проверка отрицательных остатков
        Если Режим = РежимПроведенияДокумента.Оперативный Тогда
            Если ВыборкаТовары.КоличествоОстаток < 0 Тогда
                Сообщение = Новый СообщениеПользователю();
                Сообщение.Текст = "Не хватает "
                    + Строка(-ВыборкаТовары.КоличествоОстаток)
                    + " единиц товара: "
                    + ВыборкаТовары.Товар;
                Сообщение.Сообщить();
                Отказ = Истина;
            КонецЕсли;
        КонецЕсли;

        // FIFO - запрос партий
        ЗапросПартии = Новый Запрос;
        ЗапросПартии.УстановитьПараметр("Товар", ВыборкаТовары.Товар);
        ЗапросПартии.УстановитьПараметр("МоментВремени", МоментВремени());
        ЗапросПартии.Текст =
        "ВЫБРАТЬ
        |	СтоимостьТоваровОстатки.КоличествоОстаток КАК КоличествоОстаток,
        |	СтоимостьТоваровОстатки.СтоимостьОстаток КАК СтоимостьОстаток
        |ИЗ
        |	РегистрНакопления.СтоимостьТоваров.Остатки(&МоментВремени, Товар = &Товар) КАК СтоимостьТоваровОстатки";

        РезПартии = ЗапросПартии.Выполнить();
        ВыборкаПартии = РезПартии.Выбрать();

        ОсталосьСписать = ВыборкаТовары.Количество;
        ОбщаяСебестоимость = 0;

        Пока ВыборкаПартии.Следующий() И ОсталосьСписать > 0 Цикл

            Если ВыборкаПартии.КоличествоОстаток <= ОсталосьСписать Тогда
                КоличествоИзПартии = ВыборкаПартии.КоличествоОстаток;
            Иначе
                КоличествоИзПартии = ОсталосьСписать;
            КонецЕсли;

            ЦенаЗаШтуку = ВыборкаПартии.СтоимостьОстаток / ВыборкаПартии.КоличествоОстаток;
            ОбщаяСебестоимость = ОбщаяСебестоимость + КоличествоИзПартии * ЦенаЗаШтуку;

            Движение = Движения.СтоимостьТоваров.Добавить();
            Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
            Движение.Период = Дата;
            Движение.Товар = ВыборкаТовары.Товар;
            Движение.Количество = КоличествоИзПартии;
            Движение.Стоимость = КоличествоИзПартии * ЦенаЗаШтуку;

            ОсталосьСписать = ОсталосьСписать - КоличествоИзПартии;

        КонецЦикла;

        // Регистр Продажи
        Движение = Движения.Продажи.Добавить();
        Движение.Период = Дата;
        Движение.Товар = ВыборкаТовары.Товар;
        Движение.Контрагент = Контрагент;
        Движение.Количество = ВыборкаТовары.Количество;
        Движение.Выручка = ВыборкаТовары.Сумма;
        Движение.Себестоимость = ОбщаяСебестоимость;

    КонецЦикла;

КонецПроцедуры